{
  "manifest_version": 3,
  "name": "AI Phishing Detector V3",
  "version": "1.2",
  "description": "Automatically detects phishing and fake websites using Machine Learning.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Analyze Current Website"
  },
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "notifications",
    "contextMenus",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:5000/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  }
}
